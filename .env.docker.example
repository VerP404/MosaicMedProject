# Для Docker: docker compose --env-file .env.docker up -d --build
# Либо: cp .env.docker.example .env.docker  и правьте пароли.

# --- PostgreSQL (сервис db) ---
POSTGRES_DB=mosaicmed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
# Порт Postgres на хосте (внутри контейнера всегда 5432)
# Не занимать 5432 / 5430 / 55432 (Portal и прочие стеки)
POSTGRES_PUBLISH_PORT=55433

# --- Django ---
DJANGO_ENV=prod
SECRET_KEY=change_me_django_secret_key
DEBUG_DJ=False
DEBUG_DASH=False

# --- Порты на хосте (проброс → фиксированные порты внутри контейнера) ---
# Django 5566→8000 | Dash 5567→5000 | Chief 5568→5001
# Masterd 5569→5020 | Dagster 5570→3000 | Dash DN 5571→7777
DJANGO_PORT=5566
PORT_DASH_PUBLISH=5567
PORT_DASH_CHIEF_PUBLISH=5568
MASTERD_PORT_PUBLISH=5569
DAGSTER_PORT_PUBLISH=5570
PORT_DASH_DN_PUBLISH=5571

# --- Внутри контейнера (задаются в docker-compose environment) ---
# PORT_DASH=5000, DAGSTER_PORT=3000, … — не переопределяйте здесь для Docker

DJANGO_API_BASE=http://127.0.0.1:8000
HOST_DASH=0.0.0.0
HOST_DASH_DN=0.0.0.0

# --- Опционально при старте ---
# RUN_IMPORT_INDICATORS=1

# --- ISZL / прочее ---
# В .env экранируйте $ как $$ для docker compose
ISZL_USERNAME=
ISZL_PASSWORD=
ISZL_BROWSER=chrome
ISZL_BASE_URL=http://10.36.29.2:8088/
