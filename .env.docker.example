# Скопируйте в .env в корне проекта: cp .env.docker.example .env

# --- PostgreSQL (сервис db) ---
POSTGRES_DB=mosaicmed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
# Порт на хосте (для pg_restore / DBeaver с машины)
POSTGRES_PUBLISH_PORT=5432

# --- Django prod (config/settings/prod.py: Name, USER, HOST, PORT) ---
# В compose для mosaicmed подставляются автоматически; можно задать явно:
DJANGO_ENV=prod
SECRET_KEY=change_me_django_secret_key
DEBUG_DJ=False
DEBUG_DASH=False

# --- Порты на хосте (проброс в mosaicmed) ---
DJANGO_PORT=8000
PORT_DASH=5000
PORT_DASH_CHIEF=5001
MASTERD_PORT=5020
DAGSTER_PORT=3000
PORT_DASH_DN=7777

# --- Внутри контейнера mosaicmed (localhost между процессами) ---
DJANGO_API_BASE=http://127.0.0.1:8000
HOST_DASH=0.0.0.0
HOST_DASH_DN=0.0.0.0

# --- masterd_dashboard (psycopg2) ---
# DB_* задаются в docker-compose environment

# --- Опционально при старте контейнера ---
# RUN_IMPORT_INDICATORS=1

# --- ISZL / прочее (как в update_MosaicMed.sh) ---
# В .env экранируйте $ как $$ для docker compose (например ISZL_USERNAME=025r$$c29)
ISZL_USERNAME=
ISZL_PASSWORD=
ISZL_BROWSER=chrome
ISZL_BASE_URL=http://10.36.29.2:8088/
