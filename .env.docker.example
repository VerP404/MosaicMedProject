# =============================================================================
# MosaicMed — Docker (прод / тест рядом с Portal)
# =============================================================================
# Копия:  cp .env.docker.example .env.docker
# Запуск: docker compose --env-file .env.docker up -d --build
#
# В паролях для Compose экранируйте $ как $$ (пример: pass$$word).
# Не коммитьте .env.docker (см. .gitignore).
# =============================================================================

# --- PostgreSQL (контейнер db) ---
POSTGRES_DB=mosaicmed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
# Порт Postgres НА ХОСТЕ (внутри сети Docker всегда 5432)
# Не занимать 5432 / 5430 / 55432 если там Portal / старый Postgres
POSTGRES_PUBLISH_PORT=55433

# --- Django (DJANGO_ENV=prod → config/settings/prod.py) ---
# HOST/Name/USER/PASSWORD/PORT для БД задаёт docker-compose (HOST=db).
DJANGO_ENV=prod
SECRET_KEY=change_me_long_random_django_secret_key
DEBUG_DJ=False
DEBUG_DASH=False
ORGANIZATIONS=НазваниеМО

# --- Порты на хосте → фиксированные порты внутри контейнера ---
# Внутри: Django 8000, Dash 5000, Chief 5001, Masterd 5020, Dagster 3000, DashDN 7777
# На хосте по умолчанию 5566+ (не конфликтует с нативным update_MosaicMed.sh)
DJANGO_PORT=5566
PORT_DASH_PUBLISH=5567
PORT_DASH_CHIEF_PUBLISH=5568
MASTERD_PORT_PUBLISH=5569
DAGSTER_PORT_PUBLISH=5570
PORT_DASH_DN_PUBLISH=5571

# Связь процессов внутри контейнера
DJANGO_API_BASE=http://127.0.0.1:8000
HOST_DASH=0.0.0.0
HOST_DASH_DN=0.0.0.0
DAGSTER_USE_XVFB=0

# --- Web-ОМС / Selenium (обязательно для Dagster location selenium) ---
# Без OMS_BROWSER и OMS_BASE_URL Dagster падает: Field browser/target_url must not be None
OMS_BROWSER=firefox
OMS_BASE_URL=http://10.36.0.142:9000/
OMS_USERNAME=
OMS_PASSWORD=
CHROME_DRIVER=

# Алиасы для части job'ов Dagster (можно совпадать с OMS_*)
DAGSTER_WO_URL=http://10.36.0.142:9000/
DAGSTER_WO_USER=
DAGSTER_WO_PASSWORD=
DAGSTER_WO_BROWSER=firefox

# --- ИСЗЛ / Selenium ---
ISZL_BROWSER=firefox
ISZL_BASE_URL=http://10.36.29.2:8088/
ISZL_USERNAME=
ISZL_PASSWORD=

# --- Dash ДН ---
DASH_DN_GLOBAL_ADMIN_PASSWORD=change_me
# DASH_DN_ORG=Справочник ДН
# DASH_DN_SQLITE=

# --- Telegram (опционально) ---
# TOKEN_TG=
# CHAT_ID=

# --- При старте контейнера mosaicmed (entrypoint) ---
# 1 = выполнить import_indicators_structure (структура индикаторов из fixtures)
RUN_IMPORT_INDICATORS=1

# --- Альтернатива портов «как нативно» (если 8000/5000 свободны) ---
# DJANGO_PORT=8000
# PORT_DASH_PUBLISH=5000
# PORT_DASH_CHIEF_PUBLISH=5001
# MASTERD_PORT_PUBLISH=5020
# DAGSTER_PORT_PUBLISH=3000
# PORT_DASH_DN_PUBLISH=7777
# POSTGRES_PUBLISH_PORT=5432
